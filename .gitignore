.cursorrule
.mdc 

# Python bytecode files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/

# Virtual environments
venv/
env/
ENV/
cassia_env/

# Jupyter Notebook
.ipynb_checkpoints

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Test files and directories with API keys
CASSIA_R/test_r/ 

# CASSIA test results
CASSIA/CASSIA_python/CASSIA/test_results/

# Test folder
Test/

# Social media content folder
Social/

# Feature planning (private)
Features_plan/


# Package upload scripts with potentially sensitive API keys
CASSIA_python/upload_to_pypi.py
CASSIA_python/cassia_secrets.py

# PyPI credentials (defense-in-depth — actual file lives in $HOME, not the
# repo, but this prevents accidental check-in if someone copies it locally)
.pypirc

# API key configuration files
CASSIA_R/inst/python/CASSIA/config/set_api_keys.py
**/set_api_keys.py
**/.env
**/api_keys.env

# Ignore development documentation
 dev_docs/ 
CLAUDE.md
dev_docs/quick_install_dev.py


# Claude Code session files
claude-code-session/

# R package build artifacts
*.Rcheck/
*.tar.gz
